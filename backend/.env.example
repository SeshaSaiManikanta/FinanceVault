# VaultFinance Backend — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control

# ─── Server ───
NODE_ENV=development
PORT=5000

# ─── Database ───
# Get from Supabase: Project → Settings → Database → Connection Pooling → Session Pooler
# Note: Use Session Pooler (port 5432) instead of Direct Connection for IPv4 networks
DATABASE_URL="postgresql://postgres.YOURPROJECT:PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"

# ─── JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_ACCESS_SECRET=GENERATE_A_64_BYTE_HEX_SECRET_HERE
JWT_REFRESH_SECRET=GENERATE_A_DIFFERENT_64_BYTE_HEX_SECRET_HERE

# ─── AES-256 Encryption Key (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# This encrypts Aadhaar and PAN in the database
ENCRYPTION_KEY=GENERATE_A_32_BYTE_HEX_KEY_HERE

# ─── Cookie Secret ───
COOKIE_SECRET=GENERATE_ANOTHER_SECRET_HERE

# ─── CORS ───
CLIENT_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ─── Email (Resend — https://resend.com) ───
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=VaultFinance

# ─── SMS (MSG91 — Indian SMS gateway) ───
MSG91_API_KEY=your_msg91_api_key
MSG91_SENDER_ID=VAULTF

# ─── WhatsApp (Twilio) ───
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Razorpay (Payments) ───
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── Logging ───
LOG_LEVEL=debug
